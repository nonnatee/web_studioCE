<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.WebClient" t-inherit-mode="extension">
        <!-- Cleanly replace ActionContainer with a t-if/t-else branch for Studio mode -->
        <xpath expr="//ActionContainer" position="replace">
            <t t-if="!studio.studioMode">
                <ActionContainer/>
            </t>
            <t t-else="">
                <StudioEditor/>
            </t>
        </xpath>
        <!-- Hide standard NavBar when Studio mode is active -->
        <xpath expr="//NavBar" position="attributes">
            <attribute name="t-if">!state.fullscreen &amp;&amp; !studio.studioMode</attribute>
        </xpath>
    </t>
</templates>



