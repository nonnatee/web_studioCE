<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.WebClient" t-inherit-mode="extension">
        <!-- Render StudioEditor right after the standard action container when active -->
        <xpath expr="//ActionContainer" position="after">
            <t t-if="studio.studioMode">
                <StudioEditor/>
            </t>
        </xpath>
        <!-- Hide standard ActionContainer visually when Studio mode is active (keeping DOM node intact for Owl patcher) -->
        <xpath expr="//ActionContainer" position="attributes">
            <attribute name="t-att-class">{ 'd-none': studio.studioMode }</attribute>
        </xpath>
        <!-- Hide standard NavBar visually when Studio mode is active -->
        <xpath expr="//NavBar" position="attributes">
            <attribute name="t-att-class">{ 'd-none': studio.studioMode }</attribute>
        </xpath>
    </t>
</templates>

